# DATABASE
DATABASE_URL=postgresql://sepsis_user:sepsis_password@db:5432/sepsis_db
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=sepsis_db
DATABASE_USER=sepsis_user
DATABASE_PASSWORD=sepsis_password

# BACKEND
BACKEND_URL=http://backend:8000
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# FRONTEND
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000

# REDIS (Optional, for caching)
REDIS_URL=redis://redis:6379

# SMTP (For email notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=sepsis-alert@hospital.com

# AI/ML
MODEL_PATH=/app/ml_models
USE_GPU=False

# SECURITY
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# LOGGING
LOG_LEVEL=INFO
